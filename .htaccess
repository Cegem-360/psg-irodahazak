<IfModule mod_rewrite.c>
    RewriteEngine On

    # Block direct access to sensitive files and directories
    RewriteRule ^\.env - [F,L]
    RewriteRule ^composer\.(json|lock)$ - [F,L]
    RewriteRule ^package(-lock)?\.json$ - [F,L]
    RewriteRule ^artisan$ - [F,L]
    RewriteRule ^phpunit\.xml$ - [F,L]
    RewriteRule ^webpack\.mix\.js$ - [F,L]
    RewriteRule ^vite\.config\.(js|ts)$ - [F,L]

    # Block access to application directories
    RewriteRule ^app/ - [F,L]
    RewriteRule ^bootstrap/ - [F,L]
    RewriteRule ^config/ - [F,L]
    RewriteRule ^database/ - [F,L]
    RewriteRule ^lang/ - [F,L]
    RewriteRule ^resources/ - [F,L]
    RewriteRule ^routes/ - [F,L]
    # storage/ not blocked here — public/storage symlink needs to be accessible
    # Direct storage/ access is safe because the rewrite routes to public/ anyway
    RewriteRule ^tests/ - [F,L]
    RewriteRule ^vendor/ - [F,L]
    RewriteRule ^node_modules/ - [F,L]

    # Block hidden files and directories (e.g. .git, .env.backup)
    RewriteRule (^|/)\.(?!well-known/) - [F,L]

    # Route everything else to public/
    RewriteRule ^(.*)$ public/$1 [L]
</IfModule>
